# Terraform local directories
.terraform/

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log

# Sensitive variable files — tfvars committed intentionally (no secrets, only IDs/ARNs)
# *.tfvars   <-- removed so terraform.tfvars is tracked by git

# CLI configuration files
.terraformrc
terraform.rc

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan output
*.tfplan
plan.out

# Dependency lock file
.terraform.lock.hcl

# Environment files
.env
.env.*

# OS files
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp